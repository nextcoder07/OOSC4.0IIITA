# Copy this file to backend/.env and replace the values below with your own secrets.

# Fill in your MySQL Database URL here. Make sure to append ?ssl-mode=REQUIRED or ?sslcert=... depending on requirements.
DATABASE_URL="mysql://username:password@hostname:port/database_name?ssl-mode=REQUIRED"

EMAIL_USER=your-email@example.com
EMAIL_PASS="your-email-password"
EMAIL_FROM=your-email@example.com
EMAIL_TO=recipient@example.com

# Generate with: node hash.js "YourPassword"
ADMIN_PASSWORD_HASH="$2b$12$your-bcrypt-hash-here"
JWT_SECRET=replace-with-a-strong-secret

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
