generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Speaker {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  bio       String
  photoURL  String?   
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id        Int      @id @default(autoincrement())
  name      String
  logoURL   String?
  category  String
  website   String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String 
  date        String
  time        String
  type        String
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  contact   String
  photoURL  String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  affiliation String?
  message     String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  adminEmail  String
  action      String
  resource    String
  ipAddress   String
  createdAt   DateTime @default(now())
}